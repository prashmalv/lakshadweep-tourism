# ─── Lakshadweep Tourism App — Environment Variables ──────────────────────
# Copy this file to `.env` and fill in the values before running `npm run dev`.
# NEVER commit .env — it's in .gitignore.
#
# For LOCAL DEVELOPMENT you only need ANTHROPIC_API_KEY.
# Azure vars are only needed when testing the Azure-hosted model aliases.

# ─── Required for local AI chat ────────────────────────────────────────────
# Get from https://console.anthropic.com → Settings → API Keys
# Any tier works. Set spend limit ($5–10) for safety while developing.
ANTHROPIC_API_KEY="sk-ant-api03-REPLACE-WITH-YOUR-KEY"

# ─── Optional — only if testing Azure AI Foundry alias routing ─────────────
# Get from Azure Portal → Cognitive Services → your AI Services resource → Keys
# Leave commented out for local dev unless specifically testing Azure paths.
#
# AZURE_AI_ENDPOINT="https://your-ai-resource.cognitiveservices.azure.com"
# AZURE_AI_KEY="your-azure-ai-services-key"
# AZURE_AI_API_VERSION="2024-10-21"

# ─── Optional — port override (default 3000) ───────────────────────────────
# PORT=3456
